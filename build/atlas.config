# atlas-core/build/atlas.config
# =====================================================================
# Site-local build config for assemble.sh.
#
#   atlas_core      : ..  (this repo, relative to atlas-core/build/)
#   atlas_inversion : ../../inversion-atlas
#
#   data            : /mnt/e
#                     assemble.sh creates BOTH a legacy workspace/data
#                     symlink pointing here AND a same-path mirror
#                     (workspace/mnt/e -> /mnt/e) so that absolute
#                     /mnt/e/... paths in master_config.yaml resolve
#                     under the unified server's static mount.
#
#   server_config   : atlas_server.local.yaml — WSL-local paths
#                     pointing into /mnt/e/results_inversions and
#                     /mnt/e/atlas-cache.
#
# Run build/setup_local_data.sh ONCE in WSL before the first assemble.sh
# (creates /mnt/e/atlas-cache subfolders and the per-file symlinks that
# make the new /mnt/e/results_*/ tree readable today, before raw outputs
# are physically moved out of /mnt/e/01-catfish_assembly_manuscript_CGA).
# =====================================================================

atlas_core       = ..
atlas_inversion  = ../../inversion-atlas

data             = /mnt/e

server_config    = ../server/atlas_server.local.yaml
