{
  "analysis_id":      "theta_pi",
  "analysis_version": "v1",
  "label":            "Nucleotide diversity θπ in windows",
  "description":      "Window-wise π over one sample set on a coordinate scope. Wraps region_popstats's single-group mode.",
  "inputs": {
    "sets": [
      { "role": "samples", "entity_type": "sample" },
      { "role": "windows", "entity_type": "window" }
    ],
    "artifacts": [
      { "role": "beagle", "layer_type": "beagle_file", "schema_version": "beagle_file_v1" }
    ]
  },
  "produces": [
    { "layer_type": "theta_pi_windows", "schema_version": "theta_pi_windows_v1" }
  ],
  "engine":         "region_popstats",
  "endpoint":       "/api/popstats/groupwise",
  "default_runner": "runners.popstats.run_theta",
  "status":         "active",
  "intended_use":   "diversity scans",
  "created_at":     "2026-05-12T00:00:00Z"
}
